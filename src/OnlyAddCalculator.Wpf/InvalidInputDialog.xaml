<Window x:Class="OnlyAddCalculator.Wpf.InvalidInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resources="clr-namespace:OnlyAddCalculator.Localization.Resources;assembly=OnlyAddCalculator.Localization"
        Title=""
        Width="314"
        Height="178"
        Background="White"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None">
    <Border Padding="21,34,21,24"
            Background="White"
            BorderBrush="#666666"
            BorderThickness="1">
        <StackPanel>
            <TextBlock FontFamily="Arial"
                       FontSize="17"
                       Foreground="Black"
                       Text="{x:Static resources:Strings.InvalidInputMessage}"
                       TextAlignment="Center" />

            <Button Height="43"
                    Margin="0,31,0,0"
                    Background="#4DAFEE"
                    BorderThickness="0"
                    Click="HandleGotItButtonClick"
                    Content="{x:Static resources:Strings.InvalidInputButtonText}"
                    FontFamily="Arial"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="White" />
        </StackPanel>
    </Border>
</Window>
